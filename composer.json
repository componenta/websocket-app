{
    "name": "componenta/websocket-app",
    "description": "Application integration for Componenta WebSocket server",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/app": "^1.0",
        "componenta/config": "^1.0",
        "componenta/path-resolver": "^1.0",
        "componenta/scope": "^1.0",
        "componenta/websocket-server": "^1.0",
        "psr/container": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\App\\WebSocket\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\App\\WebSocket\\Tests\\": "tests/"
        }
    },
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\App\\WebSocket\\ConfigProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
